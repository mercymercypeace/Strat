-- ==============================
-- // TBB Auto Stage Module
-- ==============================
local TBB = {}
do
    local CONFIG = {
        DELAY_AFTER_WIN  = 3,
        DELAY_AFTER_LOSE = 3,
        AUTO_RETRY       = true,
        AUTO_NEXT        = true,
        MAX_CHAPTERS     = 5,
        MAX_STAGES       = 30,
        AUTO_STARS       = true,
    }

    local State = {
        running       = false,
        chapter       = nil,
        stage         = nil,
        difficulty    = 1,
        stars         = 1,
        wins          = 0,
        losses        = 0,
        conn          = nil,
    }

    TBB.onNotify      = function(title, content, icon) end
    TBB.onStatusChange = function(text) end
    TBB.onStatsChange  = function(text) end

    local function notify(title, content, icon)
        TBB.onNotify(title, content, icon)
    end

    local function setStatus(text)
        TBB.onStatusChange(text)
    end

    local function pushStats()
        local starStr = string.rep("⭐", State.stars) .. string.rep("☆", 3 - State.stars)
        TBB.onStatsChange(string.format(
            "W: %d  L: %d  |  %s  |  Diff: %d",
            State.wins, State.losses, starStr, State.difficulty
        ))
    end

    local function getProgress()
        if State.chapter and State.chapter ~= "" then
            State.stage = State.stage or 1
            return State.chapter, State.stage
        end

        local ok, unlocked = pcall(function()
            return player:WaitForChild("PlayerData", 5):WaitForChild("Unlocked", 5)
        end)
        if not ok or not unlocked then
            notify("Error", "PlayerData not found", "alert-circle")
            return "Chapter1", 1
        end

        local bestChapter, bestStage = 1, 1
        for i = CONFIG.MAX_CHAPTERS, 1, -1 do
            local ch = unlocked:FindFirstChild("Chapter" .. i)
            if ch then
                bestChapter = i

                if ch:IsA("IntValue") or ch:IsA("NumberValue") then
                    bestStage = math.max(ch.Value, 1)
                else
                    local sv = ch:FindFirstChild("Stage")
                        or ch:FindFirstChild("Current")
                        or ch:FindFirstChild("Progress")
                    if sv and sv:IsA("ValueBase") then
                        bestStage = math.max(sv.Value, 1)
                    else
                        local hi = 0
                        for _, c in ipairs(ch:GetChildren()) do
                            local n = tonumber(c.Name)
                            if n and n > hi then hi = n end
                        end
                        if hi > 0 then bestStage = hi end
                    end
                end
                break
            end
        end

        State.stage = bestStage
        return "Chapter" .. bestChapter, bestStage
    end

    local function advanceStars()
        if not CONFIG.AUTO_STARS then
            State.stage = (State.stage or 1) + 1
            State.stars = 1
            return
        end

        if State.stars < 3 then
            State.stars = State.stars + 1
        else
            State.stars = 1
            State.stage = (State.stage or 1) + 1
            if State.stage > CONFIG.MAX_STAGES then
                notify("Done", "All stages cleared on this chapter!", "trophy")
                State.running = false
                setStatus("⏸  All stages cleared")
                return
            end
        end
    end

    local function startBattle()
        if not State.running then return end

        local events = ReplicatedStorage:FindFirstChild("Events")
        local remote  = events
            and events:FindFirstChild("RemoteFunction")
            and events.RemoteFunction:FindFirstChild("StartBattle")

        if not remote then
            notify("Error", "StartBattle remote missing", "alert-circle")
            setStatus("❌  Remote not found")
            return
        end

        local chapter, stage = getProgress()

        local starStr = string.rep("⭐", State.stars) .. string.rep("☆", 3 - State.stars)
        setStatus(string.format("▶  %s  S%d  %s  D%d", chapter, stage, starStr, State.difficulty))
        pushStats()

        pcall(function()
            remote:InvokeServer(chapter, stage, State.difficulty, State.stars, false, {}, false, 1)
        end)
    end

    local function hookWinLose()
        local winRemote = ReplicatedStorage
            :WaitForChild("Events", 10)
            :WaitForChild("RemoteEvents", 10)
            :WaitForChild("WinOrLose", 10)

        if State.conn then State.conn:Disconnect() end

        State.conn = winRemote.OnClientEvent:Connect(function(isWin)
            if not State.running then return end

            if isWin == true then
                State.wins = State.wins + 1
                advanceStars()

                if not State.running then return end

                local starStr = string.rep("⭐", State.stars) .. string.rep("☆", 3 - State.stars)
                notify("Victory!", string.format("Stage %d → next target: %s", State.stage, starStr), "trophy")
                pushStats()

                if CONFIG.AUTO_NEXT then
                    task.wait(CONFIG.DELAY_AFTER_WIN)
                    startBattle()
                end

            elseif isWin == false then
                State.losses = State.losses + 1
                notify("Defeat", "Retrying stage " .. tostring(State.stage), "refresh-cw")
                pushStats()

                if CONFIG.AUTO_RETRY then
                    task.wait(CONFIG.DELAY_AFTER_LOSE)
                    startBattle()
                end
            end
        end)
    end

    function TBB.start()
        if State.running then return end
        State.running = true
        State.wins    = 0
        State.losses  = 0
        hookWinLose()
        startBattle()
        notify("Auto Farm", "Started", "play")
        setStatus("▶  Running")
    end

    function TBB.stop()
        State.running = false
        if State.conn then State.conn:Disconnect(); State.conn = nil end
        notify("Auto Farm", "Stopped", "square")
        setStatus("⏸  Idle")
        pushStats()
    end

    function TBB.setChapter(name)
        if name == "Auto" or name == nil or name == "" then
            State.chapter = nil
        else
            State.chapter = name
        end
        State.stage   = 1
        State.stars   = 1
    end

    function TBB.setStage(n)
        State.stage = tonumber(n) or 1
        State.stars = 1
    end

    function TBB.setDifficulty(n)
        State.difficulty = math.clamp(tonumber(n) or 1, 1, 3)
    end

    function TBB.setAutoStars(bool)
        CONFIG.AUTO_STARS = bool
    end

    function TBB.resetStars()
        State.stars = 1
    end

    function TBB.getStats()
        return { wins = State.wins, losses = State.losses, stars = State.stars, stage = State.stage }
    end
end

-- ==============================
-- // TBB Projectiles Exploit Module
-- ==============================
local ProjectilesExploit = {
    running = false,
    connections = {}
}
do
    local bodyAngularList = {}

    local function trackBAV(bav)
        if bav and bav:IsA("BodyAngularVelocity") then
            bodyAngularList[bav] = true
        end
    end

    local function removeTouchInterest(descendant)
        if descendant and descendant:IsA("TouchInterest") then
            descendant:Destroy()
        end
    end

    local function getHighestHPNPC()
        local highestNPC
        local maxHealth = -math.huge
        local npcFolder = Workspace:FindFirstChild("NPCFolders")
        local enemyFolder = npcFolder and npcFolder:FindFirstChild("EnemyFolder")
        
        if enemyFolder then
            for _, npc in ipairs(enemyFolder:GetChildren()) do
                local humanoid = npc:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 and humanoid.Health > maxHealth then
                    maxHealth = humanoid.Health
                    highestNPC = npc
                end
            end
        end
        return highestNPC
    end

    local function HandleTable(tablePart)
        if not tablePart:IsA("BasePart") then return end
        local npcFolder = Workspace:FindFirstChild("NPCFolders")
        local baseFolder = npcFolder and npcFolder:FindFirstChild("BaseFolder")
        local blueBase = baseFolder and baseFolder:FindFirstChild("Blue Base")
        local blueSpawn = blueBase and blueBase:FindFirstChild("Spawn")
        if not blueSpawn then return end

        tablePart.CFrame = blueSpawn.CFrame * CFrame.new(0, -1, 0)
        tablePart.Size = tablePart.Size * 100000 
        tablePart.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
        
        local bav = tablePart:FindFirstChildOfClass("BodyAngularVelocity")
        if not bav then
            bav = Instance.new("BodyAngularVelocity")
            bav.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
            bav.AngularVelocity = Vector3.new(-40, 0, 0)
            bav.Parent = tablePart
        end
        trackBAV(bav)
        
        for _, desc in ipairs(tablePart:GetDescendants()) do
            removeTouchInterest(desc)
        end
    end

    local function HandleStoneFist(fistPart)
        if not fistPart:IsA("BasePart") then return end
        local targetNPC = getHighestHPNPC()
        if targetNPC then
            local root = targetNPC:FindFirstChild("HumanoidRootPart")
            if root then
                fistPart.CFrame = CFrame.new(root.Position + Vector3.new(0, 5, 0))
            end
        end
    end

    function ProjectilesExploit.start()
        if ProjectilesExploit.running then return end
        ProjectilesExploit.running = true

        local projectileFolder = Workspace:FindFirstChild("Projectile")
        if projectileFolder then
            for _, obj in ipairs(projectileFolder:GetChildren()) do
                if obj.Name == "Table" then
                    HandleTable(obj)
                elseif obj.Name == "StoneFist" then
                    HandleStoneFist(obj)
                end
            end

            local c1 = projectileFolder.ChildAdded:Connect(function(child)
                if not ProjectilesExploit.running then return end
                if child.Name == "Table" then
                    HandleTable(child)
                elseif child.Name == "StoneFist" then
                    HandleStoneFist(child)
                end
            end)
            table.insert(ProjectilesExploit.connections, c1)
        end

        local c2 = RunService.Heartbeat:Connect(function()
            if not ProjectilesExploit.running then return end
            for bav,_ in pairs(bodyAngularList) do
                if bav.Parent then
                    bav.AngularVelocity = Vector3.new(-40, 0, 0)
                else
                    bodyAngularList[bav] = nil
                end
            end
        end)
        table.insert(ProjectilesExploit.connections, c2)
    end

    function ProjectilesExploit.stop()
        ProjectilesExploit.running = false
        for _, conn in ipairs(ProjectilesExploit.connections) do
            if conn then conn:Disconnect() end
        end
        ProjectilesExploit.connections = {}
        bodyAngularList = {}
    end
end

